<h1 class="text-center my-4 text-primary"><%= @restaurant.name %></h1>

<div class="container">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <!-- Card Wrapper for the Restaurant Details and Reviews -->
      <div class="card shadow-lg">
        <div class="card-body">

          <!-- Restaurant Information -->
          <div class="text-center mb-4">
            <p><strong>Address:</strong> <%= @restaurant.address %></p>
            <p><strong>Category:</strong> <%= @restaurant.category.capitalize %></p>
          </div>

          <h2 class="my-4 text-center text-secondary">Reviews</h2>

          <!-- Reviews List -->
          <ul id="reviews" class="list-unstyled">
            <% @restaurant.reviews.each do |review| %>
              <%= render 'reviews/review', review: review %> <!-- Render each review using the partial -->
            <% end %>
          </ul>

          <!-- Add Review Form -->
          <%= turbo_frame_tag 'new_review' do %>
            <div class="mt-4">
              <h3 class="text-primary">Add a Review</h3>
              <%= form_with(model: @review, url: restaurant_reviews_path(@restaurant), local: true) do |form| %>
                <div class="form-group">
                  <%= form.label :rating, "Rating (0-5)", class: 'font-weight-bold' %>
                  <%= form.number_field :rating, in: 0..5, step: 1, required: true, class: "form-control" %>
                </div>

                <div class="form-group">
                  <%= form.label :content, "Review Content", class: 'font-weight-bold' %>
                  <%= form.text_area :content, required: true, class: "form-control", rows: 4 %>
                </div>
<br>
                <div class="form-group text-center">
                  <%= form.submit "Create Review", class: 'btn btn-secondary btn-lg' %>
                </div>

              <% end %>
            </div>
          <% end %>

          <!-- Back to Restaurants Button -->
          <div class="text-center mt-4">
            <%= link_to 'Back to Restaurants', restaurants_path, class: 'btn btn-secondary btn-lg' %>
          </div>

        </div>
      </div>
    </div>
  </div>
</div>
