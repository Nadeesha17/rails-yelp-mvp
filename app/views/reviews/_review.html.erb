<div class="review mb-4">
  <div class="card shadow-sm">
    <div class="card-body">
      <p><strong>Rating:</strong> <%= review.rating %> / 5</p>
      <p><strong>Content:</strong> <%= review.content %></p>

      <div class="d-flex justify-content-between mt-2">
        <!-- Delete Button -->
        <%= form_with model: review, url: restaurant_review_path(review.restaurant, review), method: :delete, data: { turbo: false, confirm: 'Are you sure?' }, class: 'd-inline' do %>
          <button type="submit" class="btn btn-danger btn-sm">Delete</button>
        <% end %>

        <!-- Edit Button -->
        <%= link_to 'Edit Review', edit_restaurant_review_path(review.restaurant, review), class: 'btn btn-warning btn-sm' %>
      </div>
    </div>
  </div>
</div>
