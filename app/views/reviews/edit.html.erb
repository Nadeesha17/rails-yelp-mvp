<!-- app/views/reviews/edit.html.erb -->

<h1 class="text-center my-4 text-primary"><%= @restaurant.name %> - Edit Review</h1>

<div class="container">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <!-- Card Wrapper for the Restaurant Details and Reviews -->
      <div class="card shadow-lg">
        <div class="card-body">

          <h3 class="my-4">Edit Review</h3>

          <%= form_with(model: [@restaurant, @review], local: true) do |form| %>
            <div class="form-group">
              <%= form.label :rating, "Rating (0-5)" %>
              <%= form.number_field :rating, in: 0..5, step: 1, required: true, class: "form-control" %>
            </div>

            <div class="form-group">
              <%= form.label :content, "Review Content" %>
              <%= form.text_area :content, required: true, class: "form-control", rows: 4 %>
            </div>

            <div class="form-group">
              <%= form.submit "Update Review", class: 'btn btn-secondary btn-lg' %>
            </div>
          <% end %>

        </div>
      </div>
    </div>
  </div>
</div>
